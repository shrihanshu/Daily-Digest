# Copy this file to ".env" and fill in your details.
# Use a Gmail APP PASSWORD (16 chars), never your real password.
# This file is gitignored — it will not be committed.

GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
GMAIL_LABEL=INBOX

# RECOMMENDED for a clean feed: only keep mail from these senders.
# Comma-separated addresses or domains. When set, nothing else is pulled.
# Example:
# GMAIL_FROM=thebatch@deeplearning.ai,newsletter@techcrunch.com,tldr@tldrnewsletter.com,dan@tldr.tech
GMAIL_FROM=

# OPTIONAL: Claude API for one-line TL;DRs on each card.
# Leave blank to skip (RSS + email still work). Top N items per day get summarised
# (caps cost). Previously generated TL;DRs are reused across runs (idempotent).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5

# OR free alternative: Google Gemini (https://aistudio.google.com/apikey).
# If ANTHROPIC_API_KEY is empty and GEMINI_API_KEY is set, Gemini is used.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

TLDR_MAX=40
