# Copy this file to ".env" and fill in your details.
# Use a Gmail APP PASSWORD (16 chars), never your real password.
# This file is gitignored — it will not be committed.

GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
GMAIL_LABEL=INBOX

# RECOMMENDED for a clean feed: only keep mail from these senders.
# Comma-separated addresses or domains. When set, nothing else is pulled.
# Example:
# GMAIL_FROM=thebatch@deeplearning.ai,newsletter@techcrunch.com,tldr@tldrnewsletter.com,dan@tldr.tech
GMAIL_FROM=
